# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep the example template, ignore real secrets)
.env
.env.local
.env*.local
!.env.example

# pwa (generated by next-pwa)
/public/sw.js
/public/sw.js.map
/public/swe-worker-*.js
/public/workbox-*.js
/public/workbox-*.js.map
/public/fallback-*.js

# local image uploads (keep the folder, ignore contents)
/public/uploads/inspections/*
!/public/uploads/inspections/.gitkeep

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
